# mimo-chat-openai - Environment Variables

# Listen address (default: :8090)
LISTEN=:8090

# Base URL for API documentation (default: http://localhost:8090)
# Set this to your domain for self-hosted deployments
# HOSTNAME=https://mimo.yourdomain.com
HOSTNAME=http://localhost:8090

# Admin password for Web UI (default: 12345678)
# Can be changed via Web UI after first login
ADMIN_PASSWORD=12345678

# SQLite database path (default: data/mimo.db)
DB_PATH=data/mimo.db

# Optional: Static API token for authentication
# If set, this token will be required for all /v1/chat/completions requests
# Takes precedence over database API keys
# API_TOKEN=your-static-token-here

# Optional: Log level (default: info)
# LOG_LEVEL=info
